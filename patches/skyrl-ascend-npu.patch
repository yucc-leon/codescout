+            kwargs["backend"] = "hccl"
+        elif len(args) > 0 and args[0] == "nccl":
+            args = ("hccl",) + args[1:]
+        return _orig_init_pg(*args, **kwargs)
+
+    torch.distributed.init_process_group = _patched_init_process_group
+
